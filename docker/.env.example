# Database
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=unt_voting
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_DATABASE=unt_voting

# Identity Server
IDENTITY_PORT=4000
DEEPFACE_URL=http://deepface-service:5000
DEEPFACE_THRESHOLD=0.95
IDENTITY_JWT_SECRET=identity_jwt_secret
IDENTITY_JWT_EXPIRES_IN=300
SALT_ROTATION_SECRET=unique_salt_for_election

# Vote Server
VOTE_PORT=3000
VOTE_JWT_SECRET=vote_jwt_secret
VOTE_JWT_EXPIRES_IN=300
BATCH_SIZE=100
BATCH_INTERVAL=60000
NOISE_RATIO=10

# Blockchain
RPC_URL=https://rpc.tanenbaum.io
SYSCOIN_RPC_URL=https://rpc.tanenbaum.io
SYSCOIN_NETWORK=testnet
PRIVATE_KEY=0x...
CONTRACT_ADDRESS=0x...

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# IPFS
IPFS_GATEWAY=https://gateway.ipfs.io
IPFS_PINATA_KEY=your_pinata_key
IPFS_PINATA_SECRET=your_pinata_secret

# Rate Limiter
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=10000

# Node Env
NODE_ENV=development
